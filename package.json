{
  "name": "@niledata/api-local",
  "version": "0.1.0",
  "description": "Local data API server for the Nile desktop data IDE",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"const{cpSync}=require('fs');cpSync('src/spark','dist/spark',{recursive:true})\"",
    "build:bundle": "npm run build && node esbuild.config.js",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.18.0",
    "toml": "^3.0.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "node-fetch": "^3.3.0",
    "@aws-sdk/credential-providers": "^3.940.0",
    "@aws-sdk/client-glue": "^3.940.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/uuid": "^9.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NileData/local.git"
  }
}
